<UserControl x:Class="CopagoAutomation.Controls.SingleDateRuleSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="400">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Modus -->
		<StackPanel Orientation="Horizontal" Margin="0,0,0,8">
			<RadioButton x:Name="ModeOneTime"
                         Content="Einmaliges Datum"
                         Margin="0,0,16,0"
                         Checked="Mode_Checked"/>
			<RadioButton x:Name="ModeRecurring"
                         Content="Wiederkehrend"
                         Checked="Mode_Checked"/>
		</StackPanel>

		<!-- Einmaliges Datum -->
		<Grid x:Name="OneTimePanel" Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			<TextBlock Text="Datum:" VerticalAlignment="Center" Margin="0,0,8,0"/>
			<DatePicker x:Name="SingleDate" Grid.Column="1" Width="160"/>
		</Grid>

		<!-- Wiederkehrend -->
		<Grid x:Name="RecurringPanel" Grid.Row="2" Visibility="Collapsed">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<!-- Gültigkeit -->
			<Grid Grid.Row="0" Margin="0,8,0,0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>
				<TextBlock Text="Gültig ab:" VerticalAlignment="Center" Margin="0,0,8,0"/>
				<DatePicker x:Name="ValidFrom" Grid.Column="1" Margin="0,0,16,0"/>
				<TextBlock Text="Gültig bis:" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0"/>
				<DatePicker x:Name="ValidTo" Grid.Column="3"/>
			</Grid>

			<!-- Regeltyp -->
			<StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
				<TextBlock Text="Regel:" VerticalAlignment="Center" Margin="0,0,8,0"/>
				<ComboBox x:Name="RuleType" Width="200" SelectionChanged="RuleType_SelectionChanged">
					<ComboBoxItem Content="Wöchentlich"/>
					<ComboBoxItem Content="Monatlich (n-ter Wochentag)"/>
				</ComboBox>
			</StackPanel>

			<!-- Wöchentlich -->
			<WrapPanel x:Name="WeeklyPanel" Grid.Row="2" Margin="0,8,0,0">
				<CheckBox x:Name="WD_Mo" Content="Mo" Margin="0,0,12,0"/>
				<CheckBox x:Name="WD_Di" Content="Di" Margin="0,0,12,0"/>
				<CheckBox x:Name="WD_Mi" Content="Mi" Margin="0,0,12,0"/>
				<CheckBox x:Name="WD_Do" Content="Do" Margin="0,0,12,0"/>
				<CheckBox x:Name="WD_Fr" Content="Fr" Margin="0,0,12,0"/>
				<CheckBox x:Name="WD_Sa" Content="Sa" Margin="0,0,12,0"/>
				<CheckBox x:Name="WD_So" Content="So" Margin="0,0,12,0"/>
			</WrapPanel>

			<!-- Monatlich -->
			<StackPanel x:Name="MonthlyPanel" Grid.Row="3" Margin="0,8,0,0" Visibility="Collapsed">
				<StackPanel Orientation="Horizontal">
					<TextBlock Text="Am:" VerticalAlignment="Center" Margin="0,0,8,0"/>
					<ComboBox x:Name="MonthOrdinal" Width="120" Margin="0,0,12,0">
						<ComboBoxItem Content="1."/>
						<ComboBoxItem Content="2."/>
						<ComboBoxItem Content="3."/>
						<ComboBoxItem Content="4."/>
						<ComboBoxItem Content="Letzter"/>
					</ComboBox>
					<ComboBox x:Name="MonthWeekday" Width="160">
						<ComboBoxItem Content="Montag"/>
						<ComboBoxItem Content="Dienstag"/>
						<ComboBoxItem Content="Mittwoch"/>
						<ComboBoxItem Content="Donnerstag"/>
						<ComboBoxItem Content="Freitag"/>
						<ComboBoxItem Content="Samstag"/>
						<ComboBoxItem Content="Sonntag"/>
					</ComboBox>
				</StackPanel>
			</StackPanel>
		</Grid>
	</Grid>
</UserControl>
