<Window x:Class="CopagoAutomation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrls="clr-namespace:CopagoAutomation.Controls"
        Title="Copago Automation"
        Height="680"
        Width="920"
        MinHeight="560"
        MinWidth="860"
        WindowStartupLocation="CenterScreen">

	<Grid Margin="14">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- Header -->
		<StackPanel Grid.Row="0" Margin="0,0,0,10">
			<TextBlock Text="CopagoOffice Report-Automation – Dashboard"
                       FontSize="20"
                       FontWeight="Bold" />
			<TextBlock x:Name="VersionText"
                       Text="Version: (noch nicht gesetzt)"
                       Margin="0,6,0,0"/>
		</StackPanel>

		<!-- Tabs -->
		<TabControl Grid.Row="1">

			<!-- ========================= -->
			<!-- TAB: ABC ANALYSE           -->
			<!-- ========================= -->
			<TabItem Header="ABC Analyse">
				<ScrollViewer VerticalScrollBarVisibility="Visible"
                              HorizontalScrollBarVisibility="Disabled">

					<Grid Margin="10">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="260"/>
						</Grid.RowDefinitions>

						<!-- Systemstatus / Modus -->
						<GroupBox Header="Systemstatus" Grid.Row="0" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<TextBlock Text="Modus:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
								<StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
									<RadioButton x:Name="AbcModeLaptop" Content="Laptop" IsChecked="True" Margin="0,0,16,0"/>
									<RadioButton x:Name="AbcModeDocking" Content="Docking"/>
								</StackPanel>

								<TextBlock Text="Aktiv:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
								<TextBlock x:Name="AbcActiveIniText"
                                           Text="Laptop | INI: (Pfad...)"
                                           Grid.Row="1" Grid.Column="1"
                                           Margin="10,8,0,0"/>

								<TextBlock Text="Status:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
								<TextBlock x:Name="AbcStatusText"
                                           Text="bereit"
                                           Grid.Row="2" Grid.Column="1"
                                           Margin="10,8,0,0"/>
							</Grid>
						</GroupBox>

						<!-- ABC Parameter -->
						<GroupBox Header="Datum Auswahl" Grid.Row="1" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="260"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<ctrls:DateRuleSelector x:Name="AbcDateRuleSelector"
                                                        Grid.Row="0"
                                                        Grid.Column="0"
                                                        Grid.ColumnSpan="2"
                                                        Margin="0,0,0,0"/>
							</Grid>
						</GroupBox>

						<!-- POS Auswahl -->
						<GroupBox Header="POS auswählen (Mehrfachauswahl mit Strg/Shift)" Grid.Row="2" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<ListBox x:Name="AbcPosList"
                                         Grid.Row="0"
                                         SelectionMode="Extended"
                                         Height="220"
                                         MinHeight="120"
                                         MaxHeight="520"/>

								<GridSplitter Grid.Row="1"
                                              Height="8"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              ResizeDirection="Rows"
                                              ResizeBehavior="PreviousAndNext"
                                              Background="Transparent" />

								<Button Grid.Row="2"
                                        Content="POS zurücksetzen"
                                        Width="160"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="AbcResetPos_Click"/>
							</Grid>
						</GroupBox>

						<!-- Speicherpfad -->
						<GroupBox Header="Speicher" Grid.Row="3" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<!-- 🔥 SaveMode Auswahl -->
								<StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal">
									<RadioButton x:Name="AbcSaveModeSemco"
                     Content="Semco Upload (Standard)"
                     IsChecked="True"
                     Margin="0,0,20,0"
                     Checked="AbcSaveModeChanged"/>

									<RadioButton x:Name="AbcSaveModeAlt"
                     Content="Alternativer Ordner"
                     Checked="AbcSaveModeChanged"/>
								</StackPanel>

								<!-- 🔹 BaseFolder -->
								<StackPanel Grid.Row="1" Grid.Column="0" Orientation="Vertical" Margin="0,10,0,0">
									<TextBlock Text="Basisordner (Semco):"/>
									<TextBox x:Name="AbcBaseFolder" Margin="0,6,0,0"/>
								</StackPanel>

								<Button Grid.Row="1" Grid.Column="1"
            Content="Browse..."
            Width="110"
            Height="30"
            Margin="12,30,0,0"
            Click="AbcBrowse_Click"/>

								<!-- 🔹 Sammelordner -->
								<StackPanel Grid.Row="2" Grid.Column="0" Orientation="Vertical" Margin="0,10,0,0">
									<TextBlock Text="Alternativer Ordner:"/>
									<TextBox x:Name="AbcSammelordner" Margin="0,6,0,0"/>
								</StackPanel>

								<Button Grid.Row="2" Grid.Column="1"
            Content="Browse..."
            Width="110"
            Height="30"
            Margin="12,30,0,0"
            Click="AbcBrowseSammelordner_Click"/>
							</Grid>
						</GroupBox>

						<!-- Start/Stop + Log -->
						<Grid Grid.Row="4">
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="*"/>
							</Grid.RowDefinitions>

							<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
								<Button Content="Kalibrieren"
                                        Width="140"
                                        Height="34"
                                        Margin="0,0,12,0"
                                        Click="AbcCalibration_Click"/>
								<Button Content="Mauspunkt übernehmen"
                                        Width="170"
                                        Height="34"
                                        Margin="0,0,12,0"
                                        Click="AbcCapturePoint_Click"/>
								<Button Content="Start"
                                        Width="140"
                                        Height="34"
                                        Margin="0,0,12,0"
                                        Click="AbcStart_Click"/>
								<Button Content="Stop"
                                        Width="140"
                                        Height="34"
                                        Click="AbcStop_Click"/>
							</StackPanel>

							<GroupBox Header="Log" Grid.Row="1">
								<TextBox x:Name="AbcLogBox"
                                         Margin="8"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"/>
							</GroupBox>
						</Grid>

					</Grid>
				</ScrollViewer>
			</TabItem>

			<!-- ========================= -->
			<!-- TAB: X-LISTE               -->
			<!-- ========================= -->
			<TabItem Header="X-Liste">
				<ScrollViewer VerticalScrollBarVisibility="Visible"
                              HorizontalScrollBarVisibility="Disabled">

					<Grid Margin="10">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="260"/>
						</Grid.RowDefinitions>

						<!-- Systemstatus / Modus -->
						<GroupBox Header="Systemstatus" Grid.Row="0" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<TextBlock Text="Modus:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
								<StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
									<RadioButton x:Name="XModeLaptop" Content="Laptop" IsChecked="True" Margin="0,0,16,0"/>
									<RadioButton x:Name="XModeDocking" Content="Docking"/>
								</StackPanel>

								<TextBlock Text="Aktiv:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
								<TextBlock x:Name="XActiveIniText"
                                           Text="Laptop | INI: (Pfad...)"
                                           Grid.Row="1" Grid.Column="1"
                                           Margin="10,8,0,0"/>

								<TextBlock Text="Status:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
								<TextBlock x:Name="XStatusText"
                                           Text="bereit"
                                           Grid.Row="2" Grid.Column="1"
                                           Margin="10,8,0,0"/>
							</Grid>
						</GroupBox>

						<!-- X-Liste Parameter -->
						<GroupBox Header="Parameter Auswahl" Grid.Row="1" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="260"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<TextBlock Text="Jahr:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
								<ComboBox x:Name="XYear"
                                          Grid.Row="0" Grid.Column="1"
                                          Width="180"/>

								<TextBlock Text="Kumuliert bis % (1-100):" Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" VerticalAlignment="Center"/>
								<TextBox x:Name="XCumPercent"
                                         Grid.Row="1" Grid.Column="1"
                                         Margin="0,10,0,0"
                                         Width="180"/>

								<TextBlock Text="Bis KW (1-52):" Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" VerticalAlignment="Center"/>
								<TextBox x:Name="XToWeek"
                                         Grid.Row="2" Grid.Column="1"
                                         Margin="0,10,0,0"
                                         Width="180"/>
							</Grid>
						</GroupBox>

						<!-- POS Auswahl -->
						<GroupBox Header="POS auswählen (Mehrfachauswahl mit Strg/Shift)" Grid.Row="2" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<ListBox x:Name="XPosList"
                                         Grid.Row="0"
                                         SelectionMode="Extended"
                                         Height="220"
                                         MinHeight="120"
                                         MaxHeight="520"/>

								<GridSplitter Grid.Row="1"
                                              Height="8"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              ResizeDirection="Rows"
                                              ResizeBehavior="PreviousAndNext"
                                              Background="Transparent" />

								<Button Grid.Row="2"
                                        Content="POS zurücksetzen"
                                        Width="160"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="XResetPos_Click"/>
							</Grid>
						</GroupBox>

						<!-- Speicherpfad -->
						<GroupBox Header="Speicher" Grid.Row="3" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical">
									<TextBlock Text="Basisordner für Reports:"/>
									<TextBox x:Name="XBaseFolder" Margin="0,6,0,0"/>
								</StackPanel>

								<Button Grid.Row="0" Grid.Column="1"
                                        Content="Browse..."
                                        Width="110"
                                        Height="30"
                                        Margin="12,22,0,0"
                                        Click="XBrowse_Click"/>

								<CheckBox Grid.Row="1" Grid.ColumnSpan="2"
                                          x:Name="XUseSammelordner"
                                          Content="Alle PDFs im gleichen Ordner speichern (Sammelordner)"
                                          Margin="0,10,0,0"/>
							</Grid>
						</GroupBox>

						<!-- Start/Stop + Log -->
						<Grid Grid.Row="4">
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="*"/>
							</Grid.RowDefinitions>

							<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
								<Button Content="Kalibrieren"
                                        Width="140"
                                        Height="34"
                                        Margin="0,0,12,0"
                                        Click="XCalibration_Click"/>
								<Button Content="Mauspunkt übernehmen"
                                        Width="170"
                                        Height="34"
                                        Margin="0,0,12,0"
                                        Click="XCapturePoint_Click"/>
								<Button Content="Start"
                                        Width="140"
                                        Height="34"
                                        Margin="0,0,12,0"
                                        Click="XStart_Click"/>
								<Button Content="Stop"
                                        Width="140"
                                        Height="34"
                                        Click="XStop_Click"/>
							</StackPanel>

							<GroupBox Header="Log" Grid.Row="1">
								<TextBox x:Name="XLogBox"
                                         Margin="8"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"/>
							</GroupBox>
						</Grid>

					</Grid>
				</ScrollViewer>
			</TabItem>

		</TabControl>
	</Grid>
</Window>