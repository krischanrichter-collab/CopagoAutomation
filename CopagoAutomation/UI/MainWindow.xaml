<Window x:Class="CopagoAutomation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrls="clr-namespace:CopagoAutomation.Controls"
        Title="Copago Automation"
        Icon="pack://application:,,,/KatzLogo.png"
        Height="680"
        Width="920"
        MinHeight="560"
        MinWidth="860"
        WindowStartupLocation="CenterScreen">

	<Grid Margin="14">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- Header -->
		<StackPanel Grid.Row="0" Margin="0,0,0,10">
			<TextBlock Text="CopagoOffice Report-Automation – Dashboard"
                       FontSize="20"
                       FontWeight="Bold" />
			<TextBlock x:Name="VersionText"
                       Text="Version: (noch nicht gesetzt)"
                       Margin="0,6,0,0"/>
		</StackPanel>

		<!-- Tabs -->
		<TabControl Grid.Row="1">

			<!-- ========================= -->
			<!-- TAB: ABC ANALYSE           -->
			<!-- ========================= -->
			<TabItem Header="ABC Analyse">
				<ScrollViewer VerticalScrollBarVisibility="Visible"
                              HorizontalScrollBarVisibility="Disabled">

					<Grid Margin="10">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="260"/>
						</Grid.RowDefinitions>

						<!-- Systemstatus / Modus -->
						<GroupBox Header="Systemstatus" Grid.Row="0" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<TextBlock Text="Modus:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
								<StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
									<RadioButton x:Name="AbcModeLaptop" Content="Laptop" IsChecked="True" Margin="0,0,16,0"/>
									<RadioButton x:Name="AbcModeDocking" Content="Docking"/>
								</StackPanel>

								<TextBlock Text="Format:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
								<StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="10,8,0,0">
									<RadioButton x:Name="AbcFormatPdf" Content="PDF" IsChecked="True" Margin="0,0,16,0"
                                                 Checked="AbcFormatChanged"/>
									<RadioButton x:Name="AbcFormatExcel" Content="Excel"
                                                 Checked="AbcFormatChanged"/>
								</StackPanel>

								<TextBlock Text="Aktiv:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
								<TextBlock x:Name="AbcActiveIniText"
                                           Text="Laptop | INI: (Pfad...)"
                                           Grid.Row="2" Grid.Column="1"
                                           Margin="10,8,0,0"/>

								<TextBlock Text="Status:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
								<TextBlock x:Name="AbcStatusText"
                                           Text="bereit"
                                           Grid.Row="3" Grid.Column="1"
                                           Margin="10,8,0,0"/>
							</Grid>
						</GroupBox>

						<!-- ABC Parameter -->
						<GroupBox Header="Datum Auswahl" Grid.Row="1" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="260"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<ctrls:DateRuleSelector x:Name="AbcDateRuleSelector"
                                                        Grid.Row="0"
                                                        Grid.Column="0"
                                                        Grid.ColumnSpan="2"
                                                        Margin="0,0,0,0"/>
							</Grid>
						</GroupBox>

						<!-- POS Auswahl -->
						<GroupBox Header="POS auswählen (Mehrfachauswahl mit Strg/Shift)" Grid.Row="2" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<ListBox x:Name="AbcPosList"
                                         Grid.Row="0"
                                         SelectionMode="Extended"
                                         Height="220"
                                         MinHeight="120"
                                         MaxHeight="520"/>

								<GridSplitter Grid.Row="1"
                                              Height="8"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              ResizeDirection="Rows"
                                              ResizeBehavior="PreviousAndNext"
                                              Background="Transparent" />

								<Button Grid.Row="2"
                                        Content="POS zurücksetzen"
                                        Width="160"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="AbcResetPos_Click"/>
							</Grid>
						</GroupBox>

						<!-- Speicherpfad -->
						<GroupBox Header="Speicher" Grid.Row="3" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<!-- 🔥 SaveMode Auswahl -->
								<StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal">
									<RadioButton x:Name="AbcSaveModeSemco"
                     Content="Semco Upload (Standard - automatische Pfade)"
                     IsChecked="True"
                     Margin="0,0,20,0"
                     Checked="AbcSaveModeChanged"/>

									<RadioButton x:Name="AbcSaveModeAlt"
                     Content="Alternativer Ordner"
                     Checked="AbcSaveModeChanged"/>
								</StackPanel>

								<!-- 🔹 Sammelordner (nur für Alternativ-Modus sichtbar) -->
								<StackPanel Grid.Row="1" Grid.Column="0" Orientation="Vertical" Margin="0,10,0,0">
									<TextBlock Text="Alternativer Ordner:"/>
									<TextBox x:Name="AbcSammelordner" Margin="0,6,0,0"/>
								</StackPanel>

								<Button Grid.Row="1" Grid.Column="1"
            Content="Browse..."
            Width="110"
            Height="30"
            Margin="12,30,0,0"
            Click="AbcBrowseSammelordner_Click"/>
							</Grid>
						</GroupBox>

						<!-- Start/Stop + Log -->
						<Grid Grid.Row="4">
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="*"/>
							</Grid.RowDefinitions>

							<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
								<Button Content="Kalibrieren"
                                        Width="140"
                                        Height="34"
                                        Margin="0,0,12,0"
                                        Click="AbcCalibration_Click"/>
								<Button x:Name="AbcStartButton"
                                        Content="Start"
                                        Width="140"
                                        Height="34"
                                        Margin="0,0,12,0"
                                        Click="AbcStart_Click"/>
								<Button x:Name="AbcStopButton"
                                        Content="Stop"
                                        Width="140"
                                        Height="34"
                                        IsEnabled="False"
                                        Click="AbcStop_Click"/>
							</StackPanel>

							<GroupBox Header="Log" Grid.Row="1">
								<TextBox x:Name="AbcLogBox"
                                         Margin="8"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"/>
							</GroupBox>
						</Grid>

					</Grid>
				</ScrollViewer>
			</TabItem>

			<!-- ========================= -->
			<!-- TAB: X-LISTE               -->
			<!-- ========================= -->
			<TabItem Header="X-Liste">
				<ScrollViewer VerticalScrollBarVisibility="Visible"
                              HorizontalScrollBarVisibility="Disabled">

					<Grid Margin="10">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="260"/>
						</Grid.RowDefinitions>

						<!-- Systemstatus / Modus -->
						<GroupBox Header="Systemstatus" Grid.Row="0" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<TextBlock Text="Modus:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
								<StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
									<RadioButton x:Name="XModeLaptop" Content="Laptop" IsChecked="True" Margin="0,0,16,0"/>
									<RadioButton x:Name="XModeDocking" Content="Docking"/>
								</StackPanel>

								<TextBlock Text="Format:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
								<StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="10,8,0,0">
									<RadioButton x:Name="XFormatPdf" Content="PDF" IsChecked="True" Margin="0,0,16,0"
                                                 Checked="XFormatChanged"/>
									<RadioButton x:Name="XFormatExcel" Content="Excel"
                                                 Checked="XFormatChanged"/>
								</StackPanel>

								<TextBlock Text="Aktiv:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
								<TextBlock x:Name="XActiveIniText"
                                           Text="Laptop | INI: (Pfad...)"
                                           Grid.Row="2" Grid.Column="1"
                                           Margin="10,8,0,0"/>

								<TextBlock Text="Status:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
								<TextBlock x:Name="XStatusText"
                                           Text="bereit"
                                           Grid.Row="3" Grid.Column="1"
                                           Margin="10,8,0,0"/>
							</Grid>
						</GroupBox>

						<!-- X-Liste Parameter -->
						<GroupBox Header="Parameter Auswahl" Grid.Row="1" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="260"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<TextBlock Text="Jahr:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
								<ComboBox x:Name="XYear"
                                          Grid.Row="0" Grid.Column="1"
                                          Width="180"/>

								<TextBlock Text="Kumuliert bis % (1-100):" Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" VerticalAlignment="Center"/>
								<TextBox x:Name="XCumPercent"
                                         Grid.Row="1" Grid.Column="1"
                                         Margin="0,10,0,0"
                                         Width="180"/>

								<TextBlock Text="KW (1-52):" Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" VerticalAlignment="Center"/>
								<TextBox x:Name="XToWeek"
                                         Grid.Row="2" Grid.Column="1"
                                         Margin="0,10,0,0"
                                         Width="180"/>
							</Grid>
						</GroupBox>

						<!-- POS Auswahl -->
						<GroupBox Header="POS auswählen (Mehrfachauswahl mit Strg/Shift)" Grid.Row="2" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<ListBox x:Name="XPosList"
                                         Grid.Row="0"
                                         SelectionMode="Extended"
                                         Height="220"
                                         MinHeight="120"
                                         MaxHeight="520"/>

								<GridSplitter Grid.Row="1"
                                              Height="8"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              ResizeDirection="Rows"
                                              ResizeBehavior="PreviousAndNext"
                                              Background="Transparent" />

								<Button Grid.Row="2"
                                        Content="POS zurücksetzen"
                                        Width="160"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="XResetPos_Click"/>
							</Grid>
						</GroupBox>

						<!-- Speicherpfad -->
						<GroupBox Header="Speicher" Grid.Row="3" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<!-- 🔥 SaveMode Auswahl -->
								<StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal">
									<RadioButton x:Name="XSaveModeSemco"
                     Content="Semco Upload (Standard - automatische Pfade)"
                     IsChecked="True"
                     Margin="0,0,20,0"
                     Checked="XSaveModeChanged"/>

									<RadioButton x:Name="XSaveModeAlt"
                     Content="Alternativer Ordner"
                     Checked="XSaveModeChanged"/>
								</StackPanel>

								<!-- 🔹 Sammelordner (nur für Alternativ-Modus sichtbar) -->
								<StackPanel Grid.Row="1" Grid.Column="0" Orientation="Vertical" Margin="0,10,0,0">
									<TextBlock Text="Alternativer Ordner:"/>
									<TextBox x:Name="XSammelordner" Margin="0,6,0,0"/>
								</StackPanel>

								<Button Grid.Row="1" Grid.Column="1"
            Content="Browse..."
            Width="110"
            Height="30"
            Margin="12,30,0,0"
            Click="XBrowseSammelordner_Click"/>
							</Grid>
						</GroupBox>

						<!-- Start/Stop + Log -->
						<Grid Grid.Row="4">
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="*"/>
							</Grid.RowDefinitions>

							<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
								<Button Content="Kalibrieren"
                                        Width="140"
                                        Height="34"
                                        Margin="0,0,12,0"
                                        Click="XCalibration_Click"/>
								<Button x:Name="XStartButton"
                                        Content="Start"
                                        Width="140"
                                        Height="34"
                                        Margin="0,0,12,0"
                                        Click="XStart_Click"/>
								<Button x:Name="XStopButton"
                                        Content="Stop"
                                        Width="140"
                                        Height="34"
                                        IsEnabled="False"
                                        Click="XStop_Click"/>
							</StackPanel>

							<GroupBox Header="Log" Grid.Row="1">
								<TextBox x:Name="XLogBox"
                                         Margin="8"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"/>
							</GroupBox>
						</Grid>

					</Grid>
				</ScrollViewer>
			</TabItem>

			<!-- ========================= -->
			<!-- TAB: STUNDENLEISTUNG       -->
			<!-- ========================= -->
			<TabItem Header="Stundenleistung">
				<ScrollViewer VerticalScrollBarVisibility="Visible"
                              HorizontalScrollBarVisibility="Disabled">

					<Grid Margin="10">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="260"/>
						</Grid.RowDefinitions>

						<!-- Systemstatus / Modus -->
						<GroupBox Header="Systemstatus" Grid.Row="0" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<TextBlock Text="Modus:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
								<StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
									<RadioButton x:Name="StundenModeLaptop" Content="Laptop" IsChecked="True" Margin="0,0,16,0"/>
									<RadioButton x:Name="StundenModeDocking" Content="Docking"/>
								</StackPanel>

								<TextBlock Text="Format:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
								<StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="10,8,0,0">
									<RadioButton x:Name="StundenFormatPdf" Content="PDF" IsChecked="True" Margin="0,0,16,0"
                                                 Checked="StundenFormatChanged"/>
									<RadioButton x:Name="StundenFormatExcel" Content="Excel"
                                                 Checked="StundenFormatChanged"/>
								</StackPanel>

								<TextBlock Text="Aktiv:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
								<TextBlock x:Name="StundenActiveIniText"
                                           Text="Laptop | INI: (Pfad...)"
                                           Grid.Row="2" Grid.Column="1"
                                           Margin="10,8,0,0"/>

								<TextBlock Text="Status:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
								<TextBlock x:Name="StundenStatusText"
                                           Text="bereit"
                                           Grid.Row="3" Grid.Column="1"
                                           Margin="10,8,0,0"/>
							</Grid>
						</GroupBox>

						<!-- Datum -->
						<GroupBox Header="Datum Auswahl" Grid.Row="1" Margin="0,0,0,10">
							<ctrls:SingleDateRuleSelector x:Name="StundenDateSelector" Margin="10"/>
						</GroupBox>

						<!-- POS Auswahl -->
						<GroupBox Header="POS auswählen (Mehrfachauswahl mit Strg/Shift)" Grid.Row="2" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<ListBox x:Name="StundenPosList"
                                         Grid.Row="0"
                                         SelectionMode="Extended"
                                         Height="220"
                                         MinHeight="120"
                                         MaxHeight="520"/>

								<GridSplitter Grid.Row="1"
                                              Height="8"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              ResizeDirection="Rows"
                                              ResizeBehavior="PreviousAndNext"
                                              Background="Transparent" />

								<Button Grid.Row="2"
                                        Content="POS zurücksetzen"
                                        Width="160"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="StundenResetPos_Click"/>
							</Grid>
						</GroupBox>

						<!-- Speicher -->
						<GroupBox Header="Speicher" Grid.Row="3" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal">
									<RadioButton x:Name="StundenSaveModeSemco"
                     Content="Semco Upload (Standard - automatische Pfade)"
                     IsChecked="True"
                     Margin="0,0,20,0"
                     Checked="StundenSaveModeChanged"/>
									<RadioButton x:Name="StundenSaveModeAlt"
                     Content="Alternativer Ordner"
                     Checked="StundenSaveModeChanged"/>
								</StackPanel>

								<StackPanel Grid.Row="1" Grid.Column="0" Orientation="Vertical" Margin="0,10,0,0">
									<TextBlock Text="Alternativer Ordner:"/>
									<TextBox x:Name="StundenSammelordner" Margin="0,6,0,0"/>
								</StackPanel>

								<Button Grid.Row="1" Grid.Column="1"
            Content="Browse..."
            Width="110"
            Height="30"
            Margin="12,30,0,0"
            Click="StundenBrowseSammelordner_Click"/>
							</Grid>
						</GroupBox>

						<!-- Start/Stop + Log -->
						<Grid Grid.Row="4">
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="*"/>
							</Grid.RowDefinitions>

							<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
								<Button Content="Kalibrieren"
                                        Width="140"
                                        Height="34"
                                        Margin="0,0,12,0"
                                        Click="StundenCalibration_Click"/>
								<Button x:Name="StundenStartButton"
                                        Content="Start"
                                        Width="140"
                                        Height="34"
                                        Margin="0,0,12,0"
                                        Click="StundenStart_Click"/>
								<Button x:Name="StundenStopButton"
                                        Content="Stop"
                                        Width="140"
                                        Height="34"
                                        IsEnabled="False"
                                        Click="StundenStop_Click"/>
							</StackPanel>

							<GroupBox Header="Log" Grid.Row="1">
								<TextBox x:Name="StundenLogBox"
                                         Margin="8"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"/>
							</GroupBox>
						</Grid>

					</Grid>
				</ScrollViewer>
			</TabItem>

			<!-- ========================= -->
			<!-- TAB: ARTIKELFREQUENZ       -->
			<!-- ========================= -->
			<TabItem Header="Artikelfrequenz">
				<ScrollViewer VerticalScrollBarVisibility="Visible"
                              HorizontalScrollBarVisibility="Disabled">

					<Grid Margin="10">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="260"/>
						</Grid.RowDefinitions>

						<!-- Systemstatus / Modus -->
						<GroupBox Header="Systemstatus" Grid.Row="0" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<TextBlock Text="Modus:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
								<StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
									<RadioButton x:Name="ArtModeLaptop" Content="Laptop" IsChecked="True" Margin="0,0,16,0"/>
									<RadioButton x:Name="ArtModeDocking" Content="Docking"/>
								</StackPanel>

								<TextBlock Text="Format:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
								<StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="10,8,0,0">
									<RadioButton x:Name="ArtFormatPdf" Content="PDF" IsChecked="True" Margin="0,0,16,0"
                                                 Checked="ArtFormatChanged"/>
									<RadioButton x:Name="ArtFormatExcel" Content="Excel"
                                                 Checked="ArtFormatChanged"/>
								</StackPanel>

								<TextBlock Text="Aktiv:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
								<TextBlock x:Name="ArtActiveIniText"
                                           Text="Laptop | INI: (Pfad...)"
                                           Grid.Row="2" Grid.Column="1"
                                           Margin="10,8,0,0"/>

								<TextBlock Text="Status:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0"/>
								<TextBlock x:Name="ArtStatusText"
                                           Text="bereit"
                                           Grid.Row="3" Grid.Column="1"
                                           Margin="10,8,0,0"/>
							</Grid>
						</GroupBox>

						<!-- Datum -->
						<GroupBox Header="Datum Auswahl" Grid.Row="1" Margin="0,0,0,10">
							<ctrls:SingleDateRuleSelector x:Name="ArtDateSelector" Margin="10"/>
						</GroupBox>

						<!-- POS Auswahl -->
						<GroupBox Header="POS auswählen (Mehrfachauswahl mit Strg/Shift)" Grid.Row="2" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<ListBox x:Name="ArtPosList"
                                         Grid.Row="0"
                                         SelectionMode="Extended"
                                         Height="220"
                                         MinHeight="120"
                                         MaxHeight="520"/>

								<GridSplitter Grid.Row="1"
                                              Height="8"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              ResizeDirection="Rows"
                                              ResizeBehavior="PreviousAndNext"
                                              Background="Transparent" />

								<Button Grid.Row="2"
                                        Content="POS zurücksetzen"
                                        Width="160"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="ArtResetPos_Click"/>
							</Grid>
						</GroupBox>

						<!-- Speicher -->
						<GroupBox Header="Speicher" Grid.Row="3" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal">
									<RadioButton x:Name="ArtSaveModeSemco"
                     Content="Semco Upload (Standard - automatische Pfade)"
                     IsChecked="True"
                     Margin="0,0,20,0"
                     Checked="ArtSaveModeChanged"/>
									<RadioButton x:Name="ArtSaveModeAlt"
                     Content="Alternativer Ordner"
                     Checked="ArtSaveModeChanged"/>
								</StackPanel>

								<StackPanel Grid.Row="1" Grid.Column="0" Orientation="Vertical" Margin="0,10,0,0">
									<TextBlock Text="Alternativer Ordner:"/>
									<TextBox x:Name="ArtSammelordner" Margin="0,6,0,0"/>
								</StackPanel>

								<Button Grid.Row="1" Grid.Column="1"
            Content="Browse..."
            Width="110"
            Height="30"
            Margin="12,30,0,0"
            Click="ArtBrowseSammelordner_Click"/>
							</Grid>
						</GroupBox>

						<!-- Start/Stop + Log -->
						<Grid Grid.Row="4">
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="*"/>
							</Grid.RowDefinitions>

							<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
								<Button Content="Kalibrieren"
                                        Width="140"
                                        Height="34"
                                        Margin="0,0,12,0"
                                        Click="ArtCalibration_Click"/>
								<Button x:Name="ArtStartButton"
                                        Content="Start"
                                        Width="140"
                                        Height="34"
                                        Margin="0,0,12,0"
                                        Click="ArtStart_Click"/>
								<Button x:Name="ArtStopButton"
                                        Content="Stop"
                                        Width="140"
                                        Height="34"
                                        IsEnabled="False"
                                        Click="ArtStop_Click"/>
							</StackPanel>

							<GroupBox Header="Log" Grid.Row="1">
								<TextBox x:Name="ArtLogBox"
                                         Margin="8"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"/>
							</GroupBox>
						</Grid>

					</Grid>
				</ScrollViewer>
			</TabItem>

		</TabControl>
	</Grid>
</Window>